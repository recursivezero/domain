


---
import GitHubIcon from "@/assets/icons/github.svg";
import MailIcon from "@/assets/icons/mail.svg";
import TwitterIcon from "@/assets/icons/x.svg";
---

<footer class="bg-white text-black">
  <!-- Top Border -->
  <div class="h-[1px] w-full bg-black/10"></div>

  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10">

    <!-- Main Grid -->
    <div class="grid gap-14 lg:grid-cols-3">

      <!-- Brand -->
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-cyan-500">
          Recursive Zero
        </p>

        <h3 class="text-4xl font-bold leading-tight">
          Building Future Ready <br />
          Digital Products
        </h3>

        <p class="mt-5 max-w-md text-lg leading-8 text-gray-600">
          We create premium web apps, internal systems and modern software
          experiences that help businesses grow faster.
        </p>
      </div>

    <!-- Replace only Quick Links section -->

<div>
  <h4 class="mb-6 text-xl font-bold">Quick Links</h4>

  <ul class="grid grid-cols-2 gap-x-10 gap-y-4 text-gray-600">
    <li><a href="/" class="transition hover:text-cyan-500">Home</a></li>
    <li><a href="/about" class="transition hover:text-cyan-500">About</a></li>
    <li><a href="/blogs" class="transition hover:text-cyan-500">Blogs</a></li>
    <li><a href="/career" class="transition hover:text-cyan-500">Career</a></li>
    <li><a href="/work" class="transition hover:text-cyan-500">Work</a></li>
    <li><a href="/contact" class="transition hover:text-cyan-500">Contact</a></li>
  </ul>
</div>

      <!-- Social -->
      <div>
        <h4 class="mb-6 text-xl font-bold">Connect With Us</h4>

        <div class="flex gap-4">

          <a
            href="https://www.twitter.com/recursivezero"
            target="_blank"
            class="flex h-12 w-12 items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 transition hover:bg-cyan-500 hover:text-white"
          >
            <TwitterIcon />
          </a>

          <a
            href="mailto:recursivezero@outlook.com"
            class="flex h-12 w-12 items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 transition hover:bg-cyan-500 hover:text-white"
          >
            <MailIcon />
          </a>

          <a
            href="https://www.github.com/recursivezero"
            target="_blank"
            class="flex h-12 w-12 items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 transition hover:bg-cyan-500 hover:text-white"
          >
            <GitHubIcon />
          </a>

        </div>

        <p class="mt-6 text-gray-600">
          hello@recursivezero.com
        </p>

        <p class="mt-2 text-gray-600">
          Bengaluru, India
        </p>
      </div>

    </div>

    <!-- Bottom -->
    <div class="mt-16 border-t border-black/10 pt-8 lg:flex lg:items-center lg:justify-between">

      <p class="text-sm text-gray-500">
        © 2025 Recursive Zero Private Limited. All rights reserved.
      </p>

      <div class="mt-4 flex gap-6 text-sm lg:mt-0">
        <a href="/terms" class="text-gray-500 transition hover:text-cyan-500">
          Terms & Conditions
        </a>

        <a href="/privacy" class="text-gray-500 transition hover:text-cyan-500">
          Privacy Policy
        </a>
      </div>

    </div>

  </div>
</footer>

