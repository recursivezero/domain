---
import contactUs from "@/assets/images/contact-us.jpeg";
import { Image } from "astro:assets";
---

<section id="contactForm" class="bg-[#07111f] text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10">

    <div class="grid items-center gap-14 lg:grid-cols-2">

      <!-- Left Content -->
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">
          Contact Us
        </p>

        <h2 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl">
          Reach Recursive Zero
        </h2>

        <p class="mt-6 max-w-xl text-lg leading-8 text-white/70">
          Tech simplified — Harness the power of modern technology with
          Recursive Zero. Send us a message and let’s build something
          impactful together.
        </p>

        <!-- Contact Info -->
        <div class="mt-8 space-y-4 text-white/70">
          <p>📧 hello@recursivezero.com</p>
          <p>📞 +91 98765 43210</p>
          <p>📍 Bengaluru, India</p>
        </div>

        <!-- Image -->
        <div class="relative mt-10">
          <div class="absolute -left-5 top-5 h-32 w-32 rounded-full bg-cyan-400/20 blur-3xl"></div>

          <Image
            src={contactUs}
            width={700}
            alt="Contact Us"
            class="relative z-10 h-[280px] w-full rounded-3xl object-cover shadow-xl"
          />
        </div>
      </div>

      <!-- Right Form -->
      <div class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-xl lg:p-10">

        <h3 class="text-2xl font-bold">
          Let's Talk
        </h3>

        <p class="mt-2 text-white/60">
          Fill the form and we’ll get back to you shortly.
        </p>

        <form class="mt-8 space-y-5">

          <input
            type="text"
            placeholder="Full Name"
            class="h-14 w-full rounded-xl border border-white/10 bg-white/10 px-5 text-white placeholder:text-white/40 outline-none focus:border-cyan-400"
          />

          <input
            type="email"
            placeholder="Email Address"
            class="h-14 w-full rounded-xl border border-white/10 bg-white/10 px-5 text-white placeholder:text-white/40 outline-none focus:border-cyan-400"
          />

          <textarea
            rows="5"
            placeholder="Your Message"
            class="w-full rounded-xl border border-white/10 bg-white/10 px-5 py-4 text-white placeholder:text-white/40 outline-none focus:border-cyan-400"
          ></textarea>

          <button
            type="submit"
            class="h-14 w-full rounded-xl bg-cyan-400 font-semibold text-black transition hover:scale-[1.02]"
          >
            Send Message
          </button>

        </form>
      </div>

    </div>
  </div>
</section>