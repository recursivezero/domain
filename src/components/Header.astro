---
import { Picture } from "astro:assets";
import logoImage from "/public/assets/images/RecursiveZero-White.jpg";

const currentPath = Astro.url.pathname;

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Blogs", href: "/blogs" },
  { name: "Career", href: "/career" },
  { name: "Work", href: "/work" }
];

const isActive = (path: string) => {
  return currentPath === path;
};
---

<header class="sticky top-0 z-50 w-full border-b border-black/10 bg-white/95 backdrop-blur-md">
  <div class="mx-auto flex h-20 w-full items-center justify-between px-8 lg:px-12">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-4">
      <Picture
        src={logoImage}
        formats={["png","webp","jpg"]}
        alt="Recursive Zero"
        class="h-14 w-auto rounded-lg object-contain"
        loading="eager"
      />

      <span class="text-3xl font-bold tracking-tight text-black">
        RECURSIVE ZERO
      </span>
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden lg:block">
      <ul class="flex items-center gap-8">
        {
          navLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class={`text-base font-medium transition duration-300 hover:text-cyan-500 ${
                  isActive(item.href)
                    ? "text-cyan-500"
                    : "text-gray-700"
                }`}
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Button -->
    <div class="hidden lg:block">
      <a
        href="/career"
        class="rounded-xl bg-black px-6 py-3 text-base font-semibold text-white transition hover:bg-cyan-500 hover:text-black"
      >
        Join Us
      </a>
    </div>

    <!-- Mobile Button -->
    <button
      id="menuBtn"
      class="rounded-lg border border-gray-300 px-3 py-2 text-black lg:hidden"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="hidden border-t bg-white px-8 py-5 lg:hidden">
    <div class="flex flex-col gap-4">
      {
        navLinks.map((item) => (
          <a
            href={item.href}
            class="text-base font-medium text-gray-700 hover:text-cyan-500"
          >
            {item.name}
          </a>
        ))
      }

      <a
        href="/career"
        class="mt-2 rounded-xl bg-black px-5 py-3 text-center font-semibold text-white"
      >
        Join Us
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");

  btn?.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>