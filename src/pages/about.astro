<section class="relative overflow-hidden bg-gradient-to-b from-[#07111f] to-[#020617] text-white">

  <!-- subtle glow -->
  <div class="absolute -top-20 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-500/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-5xl px-6 py-28 md:py-36 text-center">

    <p class="mb-4 text-sm uppercase tracking-[0.25em] text-cyan-400">
      Recursive Zero
    </p>

    <h1 class="text-5xl md:text-7xl font-bold leading-tight">
      Building Digital Products <br />
      That Drive <span class="text-cyan-400">Impact</span>
    </h1>

    <p class="mt-8 text-lg text-white/70 max-w-2xl mx-auto">
      We design and build scalable web applications, internal tools,
      and modern digital experiences.
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
      href="/contact"
    class="rounded-xl bg-cyan-400 px-6 py-3 font-semibold text-black transition hover:scale-105"
    >
      Contact Us
    </a>

      <a
        href="/work"
        class="rounded-xl border border-white/20 px-6 py-3 font-semibold text-white transition hover:bg-white hover:text-black"
      >
        View Our Work
      </a>
    </div>

  </div>
</section>


<!-- STORY -->
<section class="bg-white">
  <div class="mx-auto max-w-3xl px-6 py-20 text-center">

    <h2 class="text-4xl font-bold text-black">Our Story</h2>

    <p class="mt-6 text-lg text-gray-600 leading-8">
      Founded in 2024, Recursive Zero focuses on crafting efficient,
      scalable, and modern applications. We combine engineering excellence
      with simplicity to deliver real impact.
    </p>

  </div>
</section>


<!-- WHY CHOOSE US -->
<section class="bg-[#07111f] text-white">
  <div class="mx-auto max-w-6xl px-6 py-20">

    <h2 class="text-center text-4xl font-bold mb-12">
      Why Choose Us
    </h2>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">

      <div class="rounded-xl bg-white/5 p-6 text-center">
        <h3 class="text-3xl font-bold">50+</h3>
        <p class="text-white/70">Projects</p>
      </div>

      <div class="rounded-xl bg-white/5 p-6 text-center">
        <h3 class="text-3xl font-bold">20+</h3>
        <p class="text-white/70">Clients</p>
      </div>

      <div class="rounded-xl bg-white/5 p-6 text-center">
        <h3 class="text-3xl font-bold">99%</h3>
        <p class="text-white/70">Satisfaction</p>
      </div>

      <div class="rounded-xl bg-white/5 p-6 text-center">
        <h3 class="text-3xl font-bold">4+</h3>
        <p class="text-white/70">Years</p>
      </div>

    </div>

  </div>
</section>


<!-- TEAM -->
<section class="bg-white">
  <div class="mx-auto max-w-5xl px-6 py-20">

    <h2 class="text-center text-4xl font-bold mb-10 text-black">
      Our Team
    </h2>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2">

      <div class="rounded-2xl border p-6 text-center shadow-sm hover:shadow-xl transition">
        <h3 class="text-xl font-bold text-black">Keshav Mohta</h3>
        <p class="text-gray-500">Founder & CEO</p>
      </div>

      <div class="rounded-2xl border p-6 text-center shadow-sm hover:shadow-xl transition">
        <h3 class="text-xl font-bold text-black">Poorna Chandra</h3>
        <p class="text-gray-500">Python Developer</p>
      </div>

    </div>

  </div>
</section>


<!-- MISSION -->
<section class="bg-[#f8fafc]">
  <div class="mx-auto max-w-3xl px-6 py-20 text-center">

    <h2 class="text-4xl font-bold text-black">Our Mission</h2>

    <p class="mt-6 text-lg text-gray-600 leading-8">
      Our mission is to deliver exceptional value through innovative
      solutions and outstanding service, helping businesses grow faster.
    </p>

  </div>
</section>


<!-- CTA -->
<section class="bg-[#07111f] text-white">
  <div class="mx-auto max-w-3xl px-6 py-20 text-center">

    <h2 class="text-4xl font-bold">
      Ready to build something amazing?
    </h2>

    <p class="mt-4 text-white/70">
      Let’s turn your ideas into reality.
    </p>

    <a
      href="/contact"
      class="mt-8 inline-block rounded-xl bg-white px-6 py-3 font-semibold text-black hover:scale-105 transition"
    >
      Contact Us →
    </a>

  </div>
</section>

</BaseLayout>